# ============================================================
# DEVPULSE — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
APP_URL=http://localhost:8000
LOG_LEVEL=info

# ── Database (MySQL) ─────────────────────────────────────────
DATABASE_URL=mysql://root:password@localhost:3306/devpulse

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth / Secrets ───────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
REFRESH_TOKEN_SECRET=your-refresh-token-secret
CSRF_SECRET=your-csrf-secret

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Stripe (Payments) ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── LLM Providers (for AI features) ─────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
COHERE_API_KEY=...

# ── AWS (for S3 storage if used) ──────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=devpulse-uploads

# ── Email (Nodemailer) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
EMAIL_FROM=DevPulse <noreply@devpulse.in>

# ── Slack Alerts ─────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── GitHub App (for PR scanning) ─────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ── Sentry (Error monitoring) ────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── OpenTelemetry (Tracing) ──────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SAMPLE_RATE=0.1
SERVICE_NAME=devpulse-api

# ── Frontend (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_TS_API_URL=http://localhost:8000/trpc
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── Feature Flags ────────────────────────────────────────────
DEVPULSE_REDTEAM_SCHEDULER=false
