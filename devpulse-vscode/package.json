{
  "name": "devpulse-vscode",
  "displayName": "DevPulse",
  "description": "Stop AI agents from burning your API budget. Find leaked keys, hidden costs, and security risks in VS Code — first scan in 60 seconds.",
  "version": "0.1.0",
  "publisher": "devpulse",
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/akshaynhcm-droid/Devpulse-.git",
    "directory": "devpulse-vscode"
  },
  "bugs": {
    "url": "https://github.com/akshaynhcm-droid/Devpulse-/issues"
  },
  "homepage": "https://github.com/akshaynhcm-droid/Devpulse-#readme",
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Some features require workspace trust to access workspace files for shadow API scanning."
    }
  },
  "categories": [
    "Linters",
    "Other",
    "Testing"
  ],
  "keywords": [
    "ai security",
    "llm cost",
    "api security",
    "developer tools",
    "openai",
    "anthropic",
    "agent guard",
    "cost optimization",
    "postman",
    "openapi",
    "bruno",
    "api scanning",
    "secret detection",
    "prompt injection",
    "devpulse"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "devpulse.authenticate",
        "title": "DevPulse: Sign in with API Key",
        "icon": "$(key)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.signOut",
        "title": "DevPulse: Sign out",
        "icon": "$(sign-out)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.importCollections",
        "title": "DevPulse: Import Postman / OpenAPI collections",
        "icon": "$(cloud-upload)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.importPostman",
        "title": "DevPulse: Import Postman Collection & Scan",
        "icon": "$(file-code)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.scanCurrentFile",
        "title": "DevPulse: Scan Current File for API Security",
        "icon": "$(shield)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.refresh",
        "title": "DevPulse: Refresh",
        "icon": "$(refresh)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.runScan",
        "title": "DevPulse: Run scan",
        "icon": "$(play)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.openDashboard",
        "title": "DevPulse: Open dashboard",
        "icon": "$(globe)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.markFindingResolved",
        "title": "DevPulse: Mark finding resolved",
        "icon": "$(check)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.markFindingInProgress",
        "title": "DevPulse: Mark finding in-progress",
        "icon": "$(clock)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.openSecurityPanel",
        "title": "DevPulse: Open security dashboard",
        "icon": "$(shield)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.openSettings",
        "title": "DevPulse: Open Settings",
        "icon": "$(gear)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.askSecurityCopilot",
        "title": "DevPulse: Ask Security Copilot",
        "icon": "$(hubot)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.generateApiKey",
        "title": "DevPulse: Generate API Key",
        "icon": "$(key)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.testPromptThroughGateway",
        "title": "DevPulse: Test prompt through gateway",
        "icon": "$(beaker)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.scanShadowApis",
        "title": "DevPulse: Scan workspace for shadow APIs",
        "icon": "$(search)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.applyAutoFix",
        "title": "DevPulse: Apply auto-fix suggestion",
        "icon": "$(wand)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.dismissAutoFix",
        "title": "DevPulse: Dismiss auto-fix suggestion",
        "icon": "$(close)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.runDemo",
        "title": "DevPulse: Run Demo Scenarios",
        "icon": "$(play-circle)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.copyFindingId",
        "title": "DevPulse: Copy finding ID",
        "icon": "$(copy)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.openFindingInDashboard",
        "title": "DevPulse: Open finding in dashboard",
        "icon": "$(link-external)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.showWeeklyDigest",
        "title": "DevPulse: Show Weekly Digest",
        "icon": "$(report)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.sendFeedback",
        "title": "DevPulse: Send Feedback",
        "icon": "$(comment)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.startOnboardingTour",
        "title": "DevPulse: Start Onboarding Tour",
        "icon": "$(play)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.checkHealth",
        "title": "DevPulse: Check Health",
        "icon": "$(pulse)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.toggleCompactMode",
        "title": "DevPulse: Toggle Compact Findings Mode",
        "icon": "$(collapse-all)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.openOnboardingAnalytics",
        "title": "DevPulse: Open Onboarding Analytics",
        "icon": "$(graph)",
        "category": "DevPulse"
      },
      {
        "command": "devpulse.dismissFinding",
        "title": "DevPulse: Dismiss Finding",
        "icon": "$(close)",
        "category": "DevPulse"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devpulse",
          "title": "DevPulse",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "devpulse": [
        {
          "id": "devpulse.welcome",
          "name": "Welcome",
          "icon": "$(shield)",
          "when": "!devpulse.signedIn",
          "contextualTitle": "DevPulse Welcome"
        },
        {
          "id": "devpulse.findings",
          "name": "Findings",
          "icon": "$(shield)",
          "when": "devpulse.signedIn",
          "contextualTitle": "DevPulse Findings"
        },
        {
          "id": "devpulse.autofix",
          "name": "Auto-fix Suggestions",
          "icon": "$(lightbulb)",
          "when": "devpulse.signedIn",
          "contextualTitle": "DevPulse Auto-fix Suggestions"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "devpulse.findings",
        "contents": "Sign in with your DevPulse API key to see findings.\n[Sign in](command:devpulse.authenticate)\n\nGenerate an API key from Settings on the DevPulse dashboard."
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devpulse.refresh",
          "when": "view == devpulse.findings",
          "group": "navigation"
        },
        {
          "command": "devpulse.runScan",
          "when": "view == devpulse.findings",
          "group": "navigation"
        },
        {
          "command": "devpulse.openSecurityPanel",
          "when": "view == devpulse.findings",
          "group": "navigation"
        },
        {
          "command": "devpulse.importCollections",
          "when": "view == devpulse.findings",
          "group": "navigation"
        },
        {
          "command": "devpulse.toggleCompactMode",
          "when": "view == devpulse.findings",
          "group": "9_compact@1"
        },
        {
          "command": "devpulse.refresh",
          "when": "view == devpulse.autofix",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "devpulse.markFindingResolved",
          "when": "view == devpulse.findings && viewItem == finding",
          "group": "inline@1"
        },
        {
          "command": "devpulse.markFindingInProgress",
          "when": "view == devpulse.findings && viewItem == finding",
          "group": "inline@2"
        },
        {
          "command": "devpulse.dismissFinding",
          "when": "view == devpulse.findings && viewItem == finding",
          "group": "inline@3"
        },
        {
          "command": "devpulse.copyFindingId",
          "when": "view == devpulse.findings && viewItem == finding",
          "group": "1_actions@1"
        },
        {
          "command": "devpulse.openFindingInDashboard",
          "when": "view == devpulse.findings && viewItem == finding",
          "group": "1_actions@2"
        },
        {
          "command": "devpulse.applyAutoFix",
          "when": "view == devpulse.autofix && viewItem == autoFixSuggestion",
          "group": "inline@1"
        },
        {
          "command": "devpulse.dismissAutoFix",
          "when": "view == devpulse.autofix && viewItem == autoFixSuggestion",
          "group": "inline@2"
        }
      ],
      "commandPalette": [
        {
          "command": "devpulse.markFindingResolved",
          "when": "false"
        },
        {
          "command": "devpulse.markFindingInProgress",
          "when": "false"
        },
        {
          "command": "devpulse.applyAutoFix",
          "when": "false"
        },
        {
          "command": "devpulse.dismissAutoFix",
          "when": "false"
        },
        {
          "command": "devpulse.copyFindingId",
          "when": "false"
        },
        {
          "command": "devpulse.openFindingInDashboard",
          "when": "false"
        },
        {
          "command": "devpulse.dismissFinding",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "devpulse.refresh",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorTextFocus"
      },
      {
        "command": "devpulse.runScan",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "editorTextFocus"
      },
      {
        "command": "devpulse.openSecurityPanel",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "DevPulse",
      "properties": {
        "devpulse.apiUrl": {
          "type": "string",
          "default": "https://api.devpulse.in",
          "description": "Base URL of the DevPulse backend (default: https://api.devpulse.in — self-hosted users can override to e.g. https://api.your-company.com or http://localhost:3000)."
        },
        "devpulse.heartbeatIntervalSec": {
          "type": "number",
          "default": 120,
          "minimum": 30,
          "description": "Seconds between activity heartbeats sent to the backend. Set to 0 to disable."
        },
        "devpulse.trackFileChanges": {
          "type": "boolean",
          "default": true,
          "description": "Send file-change activity events (never includes file contents)."
        },
        "devpulse.gatewayUrl": {
          "type": "string",
          "default": "http://localhost:8081",
          "description": "Base URL of the DevPulse inline LLM gateway (default: http://localhost:8081 for local dev; override to e.g. https://gateway.your-company.com when self-hosted)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "check": "tsc --noEmit -p ./",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
