{
  "name": "devpulse",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc",
    "start": "node dist/server/_core/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:server && npm run test:frontend && npm run test:vscode",
    "test:server": "vitest run --config vitest.config.ts",
    "test:frontend": "cd devpulse-frontend && npx vitest run",
    "test:vscode": "cd devpulse-vscode && npx vitest run",
    "check": "npx tsc --noEmit && cd devpulse-vscode && npx tsc --noEmit && cd ../devpulse-frontend && npx tsc --noEmit",
    "check:all": "npm run check",
    "db:up": "docker compose up -d mysql redis",
    "db:down": "docker compose down",
    "db:migrate": "sh scripts/migrate.sh",
    "prepare": "node -e \"if (require('fs').existsSync('.git')) { try { require('child_process').execSync('husky', { stdio: 'inherit' }) } catch (e) { process.exit(1) } }\"",
    "lint": "eslint .",
    "lint:frontend": "cd devpulse-frontend && eslint .",
    "format": "npx prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "npx prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "@builder.io/vite-plugin-jsx-loc": "^0.1.1",
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@sentry/node": "^7.100.0",
    "@sentry/opentelemetry": "^10.53.1",
    "@trpc/server": "^11.6.0",
    "@vitejs/plugin-react": "^4.7.0",
    "axios": "^1.7.0",
    "bullmq": "^5.0.0",
    "compression": "^1.7.4",
    "cookie": "^0.6.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jose": "^5.2.0",
    "mysql2": "^3.9.0",
    "nanoid": "^5.0.4",
    "nodemailer": "^6.9.0",
    "pdfkit": "^0.15.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.1.0",
    "rate-limit-redis": "^4.2.0",
    "redis": "^4.6.0",
    "socket.io": "^4.7.0",
    "sqlstring": "^2.3.3",
    "stripe": "^16.0.0",
    "superjson": "^1.13.3",
    "ws": "^8.16.0",
    "xml-crypto": "^6.0.0",
    "xml2js": "^0.6.2",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npx prettier --write"
    ],
    "*.{json,md}": [
      "npx prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/compression": "^1.7.5",
    "@types/cookie": "^0.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^25.6.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.0",
    "@types/pdfkit": "^0.13.4",
    "@types/ws": "^8.5.10",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.27.0",
    "globals": "^17.6.0",
    "google-auth-library": "^10.6.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "playwright": "^1.49.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.33.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
