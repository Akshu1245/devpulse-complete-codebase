{
  "name": "@rakshex/sdk",
  "version": "0.1.0",
  "description": "RakshEx AI Runtime Telemetry SDK — drop-in wrapper for LLM providers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./openai": "./dist/wrappers/openai.js",
    "./anthropic": "./dist/wrappers/anthropic.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "@anthropic-ai/sdk": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "rakshex",
    "ai",
    "llm",
    "telemetry",
    "observability",
    "openai",
    "anthropic"
  ],
  "license": "MIT"
}
